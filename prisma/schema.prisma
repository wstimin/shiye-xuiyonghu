generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum AccountStatus {
  active
  disabled
}

enum CardStatus {
  unused
  used
  disabled
}

enum RechargeStatus {
  pending
  paid
  closed
  failed
}

enum PaymentProvider {
  alipay
  wechat
  epay
  bepusdt
}

enum BalanceLogType {
  card_redeem
  recharge
  renewal
  admin_add
  admin_subtract
  admin_set
  refund
}

enum RenewalStatus {
  success
  failed
}

model AdminUser {
  id           String        @id @default(cuid())
  username     String        @unique @db.VarChar(80)
  passwordHash String        @db.VarChar(255)
  status       AccountStatus @default(active)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  auditLogs    AuditLog[]

  @@map("admin_users")
}

model Customer {
  id              String         @id @default(cuid())
  name            String         @db.VarChar(100)
  loginUsername   String         @unique @db.VarChar(100)
  loginPasswordHash String       @db.VarChar(255)
  email           String?        @db.VarChar(160)
  phone           String?        @db.VarChar(60)
  balance         Decimal        @default(0) @db.Decimal(12, 2)
  status          AccountStatus  @default(active)
  remark          String?        @db.Text
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  nodes           CustomerNode[]
  rechargeOrders  RechargeOrder[]
  balanceLogs     BalanceLog[]
  renewalLogs     RenewalLog[]
  cards           Card[]

  @@index([status])
  @@map("customers")
}

model XuiServer {
  id          String        @id @default(cuid())
  name        String        @db.VarChar(120)
  baseUrl     String        @db.VarChar(500)
  username    String?       @db.VarChar(120)
  passwordEnc String?       @db.Text
  tokenEnc    String?       @db.Text
  basePath    String?       @db.VarChar(120)
  enabled     Boolean       @default(true)
  remark      String?       @db.Text
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  serviceNodes ServiceNode[]
  syncLogs     SyncLog[]

  @@index([enabled])
  @@map("xui_servers")
}

model ServiceNode {
  id             String         @id @default(cuid())
  serverId       String
  name           String         @db.VarChar(120)
  inboundId      Int?
  protocol       String         @default("vless") @db.VarChar(40)
  priceMonthly   Decimal        @default(0) @db.Decimal(12, 2)
  trafficLimitGb Decimal        @default(0) @db.Decimal(12, 2)
  config         Json?
  enabled        Boolean        @default(true)
  remark         String?        @db.Text
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  server         XuiServer      @relation(fields: [serverId], references: [id], onDelete: Cascade)
  customerNodes  CustomerNode[]

  @@index([serverId])
  @@index([enabled])
  @@map("service_nodes")
}

model CustomerNode {
  id             String        @id @default(cuid())
  customerId     String
  serviceNodeId  String
  xuiEmail       String        @db.VarChar(160)
  uuid           String?       @db.VarChar(80)
  expireAt       DateTime?
  trafficLimitGb Decimal       @default(0) @db.Decimal(12, 2)
  usedTrafficGb  Decimal       @default(0) @db.Decimal(12, 2)
  status         AccountStatus @default(active)
  lastSyncedAt   DateTime?
  config         Json?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  customer       Customer      @relation(fields: [customerId], references: [id], onDelete: Cascade)
  serviceNode    ServiceNode   @relation(fields: [serviceNodeId], references: [id], onDelete: Restrict)
  renewalLogs    RenewalLog[]

  @@unique([customerId, serviceNodeId])
  @@index([status])
  @@index([expireAt])
  @@map("customer_nodes")
}

model SocksNode {
  id         String   @id @default(cuid())
  name       String   @db.VarChar(120)
  host       String   @db.VarChar(255)
  port       Int
  username   String?  @db.VarChar(120)
  passwordEnc String? @db.Text
  enabled    Boolean  @default(true)
  remark     String?  @db.Text
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([enabled])
  @@map("socks_nodes")
}

model CardBatch {
  id        String   @id @default(cuid())
  templateId String?
  name      String   @db.VarChar(120)
  amount    Decimal  @db.Decimal(12, 2)
  quantity  Int
  prefix    String?  @db.VarChar(32)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  template  CardTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  cards     Card[]

  @@index([templateId])
  @@map("card_batches")
}

model CardTemplate {
  id        String   @id @default(cuid())
  name      String   @db.VarChar(120)
  amount    Decimal  @db.Decimal(12, 2)
  quantity  Int      @default(10)
  prefix    String?  @db.VarChar(32)
  enabled   Boolean  @default(true)
  remark    String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  batches   CardBatch[]

  @@index([enabled])
  @@map("card_templates")
}

model Card {
  id          String     @id @default(cuid())
  batchId     String?
  codeHash    String     @unique @db.VarChar(255)
  codePreview String     @db.VarChar(32)
  amount      Decimal    @db.Decimal(12, 2)
  status      CardStatus @default(unused)
  usedById    String?
  usedAt      DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  batch       CardBatch? @relation(fields: [batchId], references: [id], onDelete: SetNull)
  usedBy      Customer?  @relation(fields: [usedById], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([batchId])
  @@map("cards")
}

model PaymentChannel {
  id          String          @id @default(cuid())
  provider    PaymentProvider
  name        String          @db.VarChar(120)
  enabled     Boolean         @default(false)
  configEnc   Json
  sortOrder   Int             @default(0)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  orders      RechargeOrder[]

  @@index([provider, enabled])
  @@map("payment_channels")
}

model RechargeOrder {
  id          String          @id @default(cuid())
  tradeNo     String          @unique @db.VarChar(80)
  customerId  String
  channelId   String?
  provider    PaymentProvider
  amount      Decimal         @db.Decimal(12, 2)
  status      RechargeStatus  @default(pending)
  paidAt      DateTime?
  payUrl      String?         @db.Text
  qrCode      String?         @db.Text
  rawPayload  Json?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  customer    Customer        @relation(fields: [customerId], references: [id], onDelete: Cascade)
  channel     PaymentChannel? @relation(fields: [channelId], references: [id], onDelete: SetNull)
  callbacks   PaymentCallback[]

  @@index([customerId])
  @@index([provider, status])
  @@map("recharge_orders")
}

model PaymentCallback {
  id          String          @id @default(cuid())
  orderId     String?
  provider    PaymentProvider
  tradeNo     String?         @db.VarChar(80)
  verified    Boolean         @default(false)
  idempotencyKey String?      @unique @db.VarChar(160)
  payload     Json
  createdAt   DateTime        @default(now())

  order       RechargeOrder?  @relation(fields: [orderId], references: [id], onDelete: SetNull)

  @@index([provider, tradeNo])
  @@map("payment_callbacks")
}

model BalanceLog {
  id            String         @id @default(cuid())
  customerId    String
  type          BalanceLogType
  amount        Decimal        @db.Decimal(12, 2)
  beforeBalance Decimal        @db.Decimal(12, 2)
  afterBalance  Decimal        @db.Decimal(12, 2)
  operator      String?        @db.VarChar(120)
  remark        String?        @db.Text
  detail        Json?
  createdAt     DateTime       @default(now())

  customer      Customer       @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId, createdAt])
  @@map("balance_logs")
}

model RenewalLog {
  id             String        @id @default(cuid())
  customerId     String
  customerNodeId String?
  months         Int
  amount         Decimal       @db.Decimal(12, 2)
  status         RenewalStatus
  beforeExpireAt DateTime?
  afterExpireAt  DateTime?
  detail         Json?
  createdAt      DateTime      @default(now())

  customer       Customer      @relation(fields: [customerId], references: [id], onDelete: Cascade)
  customerNode   CustomerNode? @relation(fields: [customerNodeId], references: [id], onDelete: SetNull)

  @@index([customerId, createdAt])
  @@map("renewal_logs")
}

model SyncLog {
  id          String     @id @default(cuid())
  serverId    String?
  action      String     @db.VarChar(80)
  status      String     @db.VarChar(40)
  message     String?    @db.Text
  detail      Json?
  createdAt   DateTime   @default(now())

  server      XuiServer? @relation(fields: [serverId], references: [id], onDelete: SetNull)

  @@index([serverId, createdAt])
  @@map("sync_logs")
}

model SystemSetting {
  key       String   @id @db.VarChar(120)
  value     Json
  updatedAt DateTime @updatedAt

  @@map("system_settings")
}

model AuditLog {
  id          String     @id @default(cuid())
  adminUserId String?
  action      String     @db.VarChar(120)
  targetType  String?    @db.VarChar(80)
  targetId    String?    @db.VarChar(80)
  detail      Json?
  ip          String?    @db.VarChar(80)
  createdAt   DateTime   @default(now())

  adminUser   AdminUser? @relation(fields: [adminUserId], references: [id], onDelete: SetNull)

  @@index([action, createdAt])
  @@map("audit_logs")
}
